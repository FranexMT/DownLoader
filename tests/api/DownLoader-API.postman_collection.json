  "item": [
    {
      "name": "GET Estadisticas del Sistema",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Estado 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Tiempo de respuesta menor a 1000ms', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "pm.test('Content-Type es application/json', function() {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "pm.test('El body no esta vacio', function() {",
              "    pm.expect(pm.response.text()).to.not.be.empty;",
              "});",
              "pm.test('Respuesta contiene campo total', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('total');",
              "    pm.expect(json.total).to.be.a('number');",
              "});",
              "pm.test('Respuesta contiene campo completed', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('completed');",
              "    pm.expect(json.completed).to.be.a('number');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/stats",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stats"]
        }
      }
    },
