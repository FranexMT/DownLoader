    {
      "name": "POST Validar URL valida",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Estado 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Tiempo de respuesta menor a 1000ms', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "pm.test('Content-Type es application/json', function() {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "pm.test('El body no esta vacio', function() {",
              "    pm.expect(pm.response.text()).to.not.be.empty;",
              "});",
              "pm.test('URL valida retorna valid=true', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('valid');",
              "    pm.expect(json.valid).to.be.true;",
              "});",
              "pm.test('Respuesta incluye la URL enviada', function() {",
              "    var json = pm.response.json();",
              "    pm.expect(json.url).to.equal('https://example.com/archivo.zip');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\"url\": \"https://example.com/archivo.zip\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/validate-url",
          "host": ["{{baseUrl}}"],
          "path": ["api", "validate-url"]
        }
      }
    },
    {
